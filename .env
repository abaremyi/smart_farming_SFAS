# ============================================================
# SFAS — Smart Farming Advisory System
# Environment Configuration
# COPY this file to .env and fill in your real values
# NEVER commit .env to git
# ============================================================

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET_KEY=sfas_super_secret_key_change_this_in_production_2026

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3308
DB_NAME=sfas_db
DB_USER=root
DB_PASS=

# ── AI (Claude) ──────────────────────────────────────────────
# Get your free API key at: https://console.anthropic.com
# Free tier: $5 credit — enough for hundreds of farming questions
ANTHROPIC_API_KEY=sk-ant-api03-YOUR-KEY-HERE

# ── Email (PHPMailer/Gmail) ───────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=SFAS Smart Farming

# ── Weather ───────────────────────────────────────────────────
# Open-Meteo is FREE — no key needed!
# Nyagatare District coordinates (default)
WEATHER_LAT=-1.2956
WEATHER_LON=30.3256
